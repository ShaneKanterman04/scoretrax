# Web push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# In-process notification poller interval (seconds). Defaults to 60 in
# production when VAPID keys are set; 0 disables it (use an external cron
# against /api/cron/notify instead). In dev the poller is off unless set.
#PUSH_POLL_SECONDS=60

# Where push subscriptions + game snapshots are persisted (JSON file).
#PUSH_STORE_FILE=.push-store.json

# Only needed if you trigger sweeps via the /api/cron/notify route
# ("Authorization: Bearer <CRON_SECRET>") instead of the built-in poller.
CRON_SECRET=

# Optional: use Upstash Redis instead of the JSON file store (for
# serverless/multi-instance deployments).
#UPSTASH_REDIS_REST_URL=
#UPSTASH_REDIS_REST_TOKEN=
